# ─────────────────────────────────────────────────────────────
# DataCore AI Enterprise — Environment Variables
# Copy to .env.local and fill in. All optional for demo (mock data)
# except for real enterprise features (auth/billing/audit).
# ─────────────────────────────────────────────────────────────

# Supabase (required for auth + multi-tenant data + RLS)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only, service role key — used for admin ops + webhooks. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Google Gemini (AI insights + NLQ)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# Stripe (billing — test keys during development)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optional: base URL for checkout success/cancel redirects. Defaults to http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
